# ── OpenAI (LLM synthesis + Whisper transcription) ────────
OPENAI_API_KEY=sk-...

# ── ElevenLabs (audio brief + voice interview TTS) ────────
ELEVENLABS_API_KEY=...
# Voice to read the brief (default: "Rachel"). Browse at elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── HubSpot ───────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=pat-...

# ── Gong ──────────────────────────────────────────────────
GONG_ACCESS_KEY=...
GONG_ACCESS_KEY_SECRET=...

# ── Google Calendar / Gmail ───────────────────────────────
# Service account JSON path or OAuth tokens
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google-sa.json
# OR for OAuth:
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...
# Calendar ID to watch (usually the exec's email)
GOOGLE_CALENDAR_ID=cco@rokt.com

# ── Slack ─────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
# Channel or user ID to DM the briefing to
SLACK_DELIVERY_TARGET=U0123456789

# ── Asana ─────────────────────────────────────────────────
ASANA_ACCESS_TOKEN=...
ASANA_WORKSPACE_GID=...

# ── Email delivery (SMTP / Resend) ────────────────────────
# Use Resend (recommended) or any SMTP
RESEND_API_KEY=re_...
# OR SMTP:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASS=...

# Recipient
BRIEFING_EMAIL_TO=cco@rokt.com
BRIEFING_EMAIL_FROM=rokt-daily@rokt.com

# ── Scheduler ─────────────────────────────────────────────
# Cron expression for morning briefing (default: 6:30 AM Mon-Fri)
BRIEF_CRON=30 6 * * 1-5
TIMEZONE=America/New_York

# ── Webapp ────────────────────────────────────────────────
# Port the Express server listens on
PORT=3000
# Public base URL — used to build absolute audio links in emails/Slack
APP_BASE_URL=https://rokt-daily.rokt.com

# ── Misc ──────────────────────────────────────────────────
# 'email' | 'slack' | 'both'
DELIVERY_CHANNEL=both
# SQLite DB path
DB_PATH=./data/rokt-daily.db
# Log level: 'debug' | 'info' | 'error'
LOG_LEVEL=info
